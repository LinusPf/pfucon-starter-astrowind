---
/**
 * Statische Adresskarte — 0 externe Requests.
 * Zeigt Adresse als styled Card + Link zu OpenStreetMap.
 * Kein iframe, kein Script, keine Cookies.
 */
export interface Props {
  address: string;
  city: string;
  zip?: string;
  country?: string;
  lat?: number;
  lon?: number;
  zoom?: number;
  label?: string;
}

const { address, city, zip, country, lat, lon, zoom = 15, label } = Astro.props;

const displayName = label ?? `${address}, ${zip ? zip + ' ' : ''}${city}`;
const osmUrl = lat && lon
  ? `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lon}#map=${zoom}/${lat}/${lon}`
  : `https://www.openstreetmap.org/search?query=${encodeURIComponent(displayName)}`;
---

<div class="rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 p-4 flex gap-4 items-start">
  <div class="flex-shrink-0 mt-0.5">
    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
  </div>
  <div>
    <p class="font-medium text-gray-900 dark:text-white">{address}</p>
    <p class="text-gray-600 dark:text-gray-400">
      {zip && <span>{zip} </span>}{city}{country && <span>, {country}</span>}
    </p>
    <a
      href={osmUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 mt-2 text-sm text-primary hover:underline"
    >
      Auf Karte ansehen (OpenStreetMap)
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  </div>
</div>
