---
import {SITE} from 'astrowind:config'

// Env-Vars haben Vorrang vor config.yaml (pro-Kunde überschreibbar)
const googleCode = import.meta.env.PUBLIC_GSC_VERIFICATION || SITE?.googleSiteVerificationId
const bingCode   = import.meta.env.PUBLIC_BING_VERIFICATION
---

{googleCode && <meta name="google-site-verification" content={googleCode} />}
{bingCode   && <meta name="msvalidate.01"             content={bingCode} />}
