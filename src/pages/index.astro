---
import Layout from '~/layouts/PageLayout.astro';
import WidgetRenderer from '~/components/sanity/WidgetRenderer.astro';
import { fetchHomePage } from '~/lib/queries';
import { isSanityConfigured } from '~/lib/sanity';

// fetchHomePage() returns null when Sanity is not configured or unreachable.
// The build will NOT crash in either case.
const data = await fetchHomePage();

const metadata = {
  title: data?.title ?? 'PfuCon Starter',
  description: data?.description,
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  {!isSanityConfigured && (
    <div class="bg-yellow-50 dark:bg-yellow-900/30 border-l-4 border-yellow-400 p-6 m-6 rounded-md">
      <p class="font-semibold text-yellow-800 dark:text-yellow-200 mb-1">Sanity nicht konfiguriert</p>
      <p class="text-yellow-700 dark:text-yellow-300 text-sm">
        Setze <code class="font-mono bg-yellow-100 dark:bg-yellow-900 px-1 rounded">PUBLIC_SANITY_PROJECT_ID</code> in
        deiner <code class="font-mono bg-yellow-100 dark:bg-yellow-900 px-1 rounded">.env</code>-Datei.
        Siehe <strong>README.md</strong> für den Setup-Ablauf.
      </p>
    </div>
  )}

  {isSanityConfigured && !data && (
    <div class="bg-red-50 dark:bg-red-900/30 border-l-4 border-red-400 p-6 m-6 rounded-md">
      <p class="font-semibold text-red-800 dark:text-red-200 mb-1">Keine Homepage-Daten in Sanity</p>
      <p class="text-red-700 dark:text-red-300 text-sm">
        Öffne das Sanity Studio (<code class="font-mono bg-red-100 dark:bg-red-900 px-1 rounded">cd studio && npm run dev</code>)
        und lege ein Homepage-Dokument mit mindestens einem Widget an.
      </p>
    </div>
  )}

  {data?.pageBuilder && data.pageBuilder.length > 0 && (
    <WidgetRenderer pageBuilder={data.pageBuilder} />
  )}
</Layout>
