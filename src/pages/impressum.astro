---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Impressum',
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <h1 class="text-3xl font-bold mb-8">Impressum</h1>

    <!-- ═══════════════════════════════════════════════════════════════
         TODO: Pflichtangaben nach § 5 ECG (AT) / § 5 TMG (DE) befüllen
         ═══════════════════════════════════════════════════════════════ -->

    <div class="prose dark:prose-invert max-w-none">

      <h2>Angaben gemäß § 5 ECG</h2>

      <p>
        <strong>[UNTERNEHMENSNAME]</strong><br />
        [RECHTSFORM, z. B. Einzelunternehmen / GmbH]<br />
        [STRAßE HAUSNUMMER]<br />
        [PLZ] [ORT]<br />
        Österreich
      </p>

      <h2>Kontakt</h2>
      <p>
        Telefon: <a href="tel:[TELEFONNUMMER]">[TELEFONNUMMER]</a><br />
        E-Mail: <a href="mailto:[EMAIL]">[EMAIL]</a>
      </p>

      <h2>Unternehmensgegenstand</h2>
      <p>[UNTERNEHMENSGEGENSTAND / TÄTIGKEITSBESCHREIBUNG]</p>

      <h2>Aufsichtsbehörde / Kammer</h2>
      <p>
        [z. B. Wirtschaftskammer Österreich, Fachgruppe ...]<br />
        Berufsrecht: <a href="https://www.ris.bka.gv.at/" target="_blank" rel="noopener noreferrer">www.ris.bka.gv.at</a>
      </p>

      {/* Nur für GmbH / AG / Genossenschaft: */}
      {/*
      <h2>Firmenbuch</h2>
      <p>
        Firmenbuchnummer: FN [NUMMER]x<br />
        Firmenbuchgericht: Landesgericht [GERICHT]
      </p>
      */}

      <h2>UID-Nummer</h2>
      <p>ATU[NUMMER] <em>(oder entfernen wenn nicht vorhanden)</em></p>

      <h2>Haftungsausschluss</h2>
      <p>
        Trotz sorgfältiger inhaltlicher Kontrolle übernehmen wir keine Haftung für die Inhalte externer Links.
        Für den Inhalt der verlinkten Seiten sind ausschließlich deren Betreiber verantwortlich.
      </p>

      <h2>Urheberrecht</h2>
      <p>
        Die auf dieser Website veröffentlichten Inhalte unterliegen dem österreichischen Urheberrecht.
        Jede Nutzung außerhalb der Grenzen des Urheberrechts bedarf der vorherigen schriftlichen Zustimmung
        des jeweiligen Autors bzw. Erstellers.
      </p>

    </div>
  </section>
</Layout>
