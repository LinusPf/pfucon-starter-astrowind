# ── Sanity ──────────────────────────────────────────────────────────────────
# Project-ID aus https://sanity.io/manage
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# ── Search Console & Bing Webmaster ─────────────────────────────────────────
# Nur setzen wenn DNS-Verify nicht möglich (Meta-Tag-Fallback)
PUBLIC_GSC_VERIFICATION=
PUBLIC_BING_VERIFICATION=

# ── Analytics ───────────────────────────────────────────────────────────────
# Plausible: Domain der Website (z. B. example.at)
PUBLIC_PLAUSIBLE_DOMAIN=
# Self-hosted Plausible (leer lassen = plausible.io)
PUBLIC_PLAUSIBLE_URL=
